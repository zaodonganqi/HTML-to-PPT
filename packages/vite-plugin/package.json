{
  "name": "@htp/vite-plugin",
  "version": "0.0.1",
  "private": true,
  "description": "Vite plugin for HTP — auto-export PPTX after build",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@htp/core": "workspace:*",
    "@htp/exporter": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vite": "^5.0.0"
  },
  "peerDependencies": {
    "vite": "^5.0.0 || ^6.0.0"
  }
}
