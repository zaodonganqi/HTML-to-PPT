{
  "name": "@htp/cli",
  "version": "0.0.1",
  "private": true,
  "description": "CLI for HTP — export HTML to PowerPoint from the command line",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "htp": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup src/cli.ts --format esm --clean",
    "dev": "tsup src/cli.ts --format esm --watch",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@htp/exporter": "workspace:*",
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  }
}
